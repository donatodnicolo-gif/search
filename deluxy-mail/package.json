    "db:seed": "node --env-file=.env prisma/seed.mjs",
    "tauri": "tauri"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "imapflow": "^1.0.164",
    "mailparser": "^3.7.1",
    "next": "^15.3.0",
    "nodemailer": "^6.9.15",
    "openai": "^4.77.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/mailparser": "^3.4.5",
    "@types/node": "^22.13.10",
    "@types/nodemailer": "^6.4.16",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "prisma": "^6.5.0",
    "typescript": "^5.7.3"
  }
