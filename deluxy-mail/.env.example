# AI MAIL 2.0 — variabili d'ambiente (copiare in .env e compilare)
# NON committare mai il file .env.

# Database Postgres (come deluxy-partner: pooled + diretto per le migrazioni)
DATABASE_URL="postgresql://utente:password@host:5432/deluxymail?pgbouncer=true"
DIRECT_URL="postgresql://utente:password@host:5432/deluxymail"

# Chiave OpenAI: sta SOLO qui, sul server. Mai su desktop o Android.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# Segreto per cifrare le password IMAP/SMTP salvate nel database.
# Generare con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_SECRET=""

# Per entrare servono email autorizzata + password.
APP_PASSWORD=""
# Email abilitate all'accesso, separate da virgola. Se vuota, va inserita
# un'email qualsiasi (obbligatoria) ma non viene confrontata con un elenco.
APP_EMAIL="nicolo.donato@deluxy.it"

# Token per far girare la sincronizzazione da un cron esterno:
# GET /api/sync?token=...
CRON_TOKEN=""
