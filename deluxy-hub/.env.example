# Database: Postgres Supabase, lo stesso di deluxy-partner ma nello schema "hub".
# Lo "?schema=hub" è obbligatorio: senza, prisma db push lavorerebbe sullo schema
# public e finirebbe sui dati di Partner.
DATABASE_URL="postgresql://…:6543/postgres?pgbouncer=true&connection_limit=1&schema=hub"
DIRECT_URL="postgresql://…:5432/postgres?schema=hub"

# Segreto per firmare il cookie di sessione. Cambiandolo si invalidano tutte le sessioni.
# Generane uno con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
HUB_SESSION_SECRET="cambiami-in-un-segreto-lungo-e-casuale"

# (Facoltativo) Cifra i valori della pagina /chiavi (AES-256-GCM). Se non lo
# imposti, si riusa HUB_SESSION_SECRET, così la cassaforte funziona senza
# configurare nulla. Impostane uno dedicato per isolare la cassaforte dai cookie:
# minimo 32 caratteri; cambiandolo, le chiavi già salvate diventano illeggibili.
# Generane uno con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# HUB_CHIAVI_SECRET="cambiami-in-un-segreto-lungo-e-casuale"

# Token di servizio per l'API /api/chiavi: le altre app lo presentano (header
# X-Hub-Token) per farsi restituire le proprie chiavi dalla cassaforte, invece
# di tenerle nel .env. È un SEGRETO di primo livello (chi ce l'ha legge le chiavi
# in chiaro): minimo 16 caratteri, va messo qui e nell'env di ogni app client.
# Generane uno con: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
# HUB_KEYS_TOKEN="cambiami-in-un-token-lungo-e-casuale"

# Single Sign-On: segreto CONDIVISO con le app che accettano il login dal Hub
# (per ora deluxy-partner). Deve essere IDENTICO qui e nell'app di destinazione.
# Minimo 32 caratteri. Generane uno con:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
HUB_SSO_SECRET="cambiami-e-usa-lo-stesso-valore-nelle-app"

# URL delle app collegate (le icone della home puntano qui)
APP_URL_CONSEGNE="https://deluxy-delivery.vercel.app"
APP_URL_SEARCH="https://search-deluxy.vercel.app"
APP_URL_PARTNER="http://localhost:3040"
APP_URL_ANAGRAFICHE="http://localhost:3060"
APP_URL_MAISON="https://deluxy-os.base44.app/"
APP_URL_SCOUT="https://deluxy-scout.vercel.app"
APP_URL_MAIL="http://localhost:3070"
APP_URL_TASKS="http://localhost:3090"
APP_URL_CALENDARIO="http://localhost:3110"
APP_URL_MERCHANDISING="http://localhost:3120"

# Password dell'utente admin creato dal seed (solo primo avvio)
SEED_ADMIN_EMAIL="deluxy.delivery@gmail.com"
SEED_ADMIN_PASSWORD="cambiami"
