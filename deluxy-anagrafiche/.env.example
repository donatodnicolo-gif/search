# Postgres condiviso delle app Deluxy (stesso cluster di hub/partner), schema "anagrafiche".
# Genera questo file con: node scripts/configura-db-condiviso.mjs <env-di-un-altra-app>
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true&schema=anagrafiche"
DIRECT_URL="postgresql://user:password@host:5432/postgres?schema=anagrafiche"

# Password unica della UI (come deluxy-partner). Se assente (sviluppo locale) la UI è aperta.
# Le API /api/v1 non usano questa password: hanno le chiavi API.
# ANAGRAFICHE_APP_PASSWORD="..."

# Sezione "Sync HubSpot": token di Private App HubSpot con permesso
# crm.objects.companies.read (sola lettura). Senza token la pagina spiega come configurarlo.
# HUBSPOT_ACCESS_TOKEN="pat-eu1-..."
