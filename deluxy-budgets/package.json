{
  "name": "deluxy-budgets",
  "version": "0.1.0",
  "private": true,
  "description": "Deluxy Budgets — budget aziendali, P&L, premi su 3 livelli, proposte dei responsabili e spese ADV",
  "scripts": {
    "dev": "next dev -p 3080",
    "build": "prisma generate && next build",
    "postinstall": "prisma generate",
    "start": "next start -p 3080",
    "db:push": "prisma db push",
    "db:seed": "node prisma/seed.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "next": "^15.3.0",
    "openai": "^6.48.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "prisma": "^6.5.0",
    "typescript": "^5.7.3"
  },
  "allowScripts": {
    "prisma@6.19.3": true,
    "sharp@0.34.5": true,
    "@prisma/client@6.19.3": true,
    "@prisma/engines@6.19.3": true
  }
}
