# Sviluppo locale: SQLite (nessun segreto). In produzione passare a Postgres
# (cambiare provider in prisma/schema.prisma) e usare le chiavi Supabase.
DATABASE_URL="file:./dev.db"

# Consuntivo per tipologia dall'app Finance (deluxy-partner).
# FINANCE_API_KEY è la stessa chiave di /api/verifiche di Finance: è un SEGRETO,
# non committarla. FINANCE_API_URL è opzionale (default: produzione).
FINANCE_API_URL="https://deluxy-partner.vercel.app"
FINANCE_API_KEY=""

