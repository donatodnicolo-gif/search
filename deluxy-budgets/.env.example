# Sviluppo locale: SQLite (nessun segreto). In produzione passare a Postgres
# (cambiare provider in prisma/schema.prisma) e usare le chiavi Supabase.
DATABASE_URL="file:./dev.db"

# --- Chiavi dalla cassaforte del Hub ---
# Le chiavi (FINANCE_API_KEY, OPENAI_API_KEY, …) NON si tengono più qui: si
# chiedono al Hub (pagina /chiavi, progetto "deluxy-budgets"). L'unico segreto
# locale è il token di servizio, uguale a HUB_KEYS_TOKEN del Hub.
HUB_URL="https://deluxy-hub.vercel.app"
HUB_KEYS_TOKEN=""

# URL dei servizi (non segreti): opzionali, default alla produzione.
FINANCE_API_URL="https://deluxy-partner.vercel.app"
OPENAI_MODEL="gpt-4o-mini"

# In sviluppo puoi ancora mettere una chiave qui per lavorare offline: se
# presente, l'env locale ha la precedenza sul Hub.
# FINANCE_API_KEY=""
# OPENAI_API_KEY=""

