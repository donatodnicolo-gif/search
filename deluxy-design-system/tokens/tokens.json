{
  "$schema": "https://design-tokens.org",
  "name": "Deluxy Design System",
  "version": "1.0.0",
  "color": {
    "bg": "#F5F5F7",
    "surface": "#FFFFFF",
    "surfaceTranslucent": "rgba(255, 255, 255, 0.72)",
    "text": "#1D1D1F",
    "textSecondary": "#6E6E73",
    "textTertiary": "#86868B",
    "hairline": "rgba(0, 0, 0, 0.08)",
    "hairlineStrong": "rgba(0, 0, 0, 0.14)",
    "fill": "rgba(120, 120, 128, 0.08)",
    "fillHover": "rgba(120, 120, 128, 0.14)",
    "fillActive": "rgba(120, 120, 128, 0.20)",
    "ink": "#111318",
    "inkHover": "#2A2D35",
    "gold": "#B8963E",
    "goldStrong": "#A07F2C",
    "goldSoft": "rgba(184, 150, 62, 0.12)",
    "blue": "#0071E3",
    "green": "#248A3D",
    "orange": "#C93400",
    "red": "#D70015",
    "purple": "#6D3FC4"
  },
  "statusTint": {
    "comment": "Sfondo badge = colore semantico al 9-12%; testo = colore pieno",
    "created": { "bg": "rgba(255, 149, 0, 0.12)", "text": "#B25000" },
    "assigned": { "bg": "rgba(0, 113, 227, 0.10)", "text": "#0071E3" },
    "inDelivery": { "bg": "rgba(109, 63, 196, 0.11)", "text": "#6D3FC4" },
    "delivered": { "bg": "rgba(36, 138, 61, 0.12)", "text": "#248A3D" },
    "cancelled": { "bg": "rgba(215, 0, 21, 0.09)", "text": "#D70015" },
    "neutral": { "bg": "rgba(120, 120, 128, 0.08)", "text": "#6E6E73" }
  },
  "typography": {
    "fontFamily": "-apple-system, BlinkMacSystemFont, 'SF Pro Text', 'SF Pro Display', 'Segoe UI Variable', 'Segoe UI', system-ui, Roboto, Helvetica, Arial, sans-serif",
    "fontFamilyLogo": "Georgia, 'Times New Roman', serif",
    "titleXl": { "size": 32, "weight": 600, "tracking": -0.025 },
    "titleL": { "size": 24, "weight": 600, "tracking": -0.022 },
    "titleM": { "size": 19, "weight": 600, "tracking": -0.02 },
    "body": { "size": 15, "weight": 400 },
    "bodyS": { "size": 14, "weight": 400 },
    "caption": { "size": 13, "weight": 400 },
    "label": { "size": 11, "weight": 600, "tracking": 0.06, "uppercase": true }
  },
  "spacing": [4, 8, 12, 16, 20, 24, 32, 44],
  "radius": { "s": 8, "m": 12, "l": 18, "xl": 24, "pill": 980 },
  "shadow": {
    "card": "0 1px 2px rgba(0,0,0,0.04), 0 8px 24px rgba(0,0,0,0.05)",
    "float": "0 4px 12px rgba(0,0,0,0.08), 0 24px 60px rgba(0,0,0,0.12)"
  },
  "motion": {
    "ease": "cubic-bezier(0.25, 0.1, 0.25, 1)",
    "durationPress": 150,
    "durationColor": 180,
    "durationOverlay": 280,
    "pressScale": 0.97
  },
  "blur": { "bar": 24, "modal": 30, "saturate": 1.8 }
}
