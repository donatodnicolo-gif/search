# Deluxy Messaggi — variabili d'ambiente (copiare in .env, MAI committare valori)

# Postgres (Supabase): pooled per l'app, diretta per prisma db push
DATABASE_URL="postgresql://..."
DIRECT_URL="postgresql://..."

# Segreto dell'app: firma le sessioni e cifra i token Meta salvati nel database
APP_SECRET="una-stringa-lunga-e-casuale"

# URL pubblico dell'app (usato per mostrare l'URL del webhook e lo snippet del widget)
APP_URL="http://localhost:3140"
