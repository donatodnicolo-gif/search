# ─────────────────────────────────────────────────────────────
# Deluxy Scout — variabili d'ambiente
# Copia questo file in `.env` e riempi i valori. `.env` NON va committato.
# ─────────────────────────────────────────────────────────────

# --- Supabase ---
# Dashboard Supabase → Project Settings → API
# La anon key è pubblica per design (protetta da Row Level Security).
EXPO_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# --- Google Maps (chiavi native per react-native-maps) ---
# Console Google Cloud → APIs & Services → Credentials
# Servono le API: "Maps SDK for Android" e "Maps SDK for iOS".
EXPO_PUBLIC_GOOGLE_MAPS_ANDROID_KEY=AIza...
EXPO_PUBLIC_GOOGLE_MAPS_IOS_KEY=AIza...

# --- HubSpot sync (Edge Function) ---
# URL della Supabase Edge Function `hubspot-sync` che fa da proxy verso HubSpot.
# Es: https://xxxxxxxxxxxxx.functions.supabase.co/hubspot-sync
# Il TOKEN HubSpot NON sta qui (finirebbe nel bundle): è un secret della Edge Function.
EXPO_PUBLIC_HUBSPOT_SYNC_URL=https://xxxxxxxxxxxxx.functions.supabase.co/hubspot-sync

# --- EAS (build) ---
EAS_PROJECT_ID=

# ─────────────────────────────────────────────────────────────
# SEGRETI LATO SERVER — NON vanno in questo file .env dell'app.
# Si impostano come secret della Edge Function con:
#   supabase secrets set HUBSPOT_TOKEN=pat-xx-xxxx
#   supabase secrets set SUPABASE_SERVICE_ROLE_KEY=eyJ...
#
# HUBSPOT_TOKEN — Private App token HubSpot.
#   Scope richiesti: crm.objects.companies.read/write,
#   crm.objects.contacts.read/write, crm.objects.deals.read/write,
#   crm.objects.notes.read/write (o "sales-email-read" per gli engagement).
# ─────────────────────────────────────────────────────────────
