# ─────────── Database ───────────
# Postgres condiviso Deluxy, schema "marketing".
# Si genera da solo copiando le credenziali di un'altra app Deluxy:
#   npm run configura-db -- ../deluxy-hub/.env.vercel-prod
DATABASE_URL=postgresql://…?schema=marketing&pgbouncer=true
DIRECT_URL=postgresql://…?schema=marketing

# ─────────── Protezione della UI ───────────
# Password unica del team. Se manca, la UI è aperta (solo sviluppo locale).
MARKETING_APP_PASSWORD=

# ─────────── Google Drive ───────────
# Cartella locale (Google Drive per Desktop) oppure link alla cartella online.
DRIVE_ADV_DIR=G:\Il mio Drive\ADV DELUXY SRL
# Chiave API Google (Drive API abilitata) per leggere il Drive online da server
GOOGLE_DRIVE_API_KEY=

# ─────────── Shopify (import ordini) ───────────
# SHOPIFY_NEGOZI=deluxygifts:gifts,fb72b1-2:flowers,cakedesign-5921:cake
# SHOPIFY_TOKEN_DELUXYGIFTS=shpat_…
# SHOPIFY_TOKEN_FB72B12=shpat_…
# SHOPIFY_TOKEN_CAKEDESIGN5921=shpat_…

# ─────────── Chiave dell'app per gli script esterni ───────────
# Creata con: npm run chiave -- google-ads
MARKETING_API_KEY=
