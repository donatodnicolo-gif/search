// Deluxy Partner — schema dati
// Sostituisce PARTNER.xlsx (Database clienti 2026): ogni foglio/blocco Excel
// diventa un'entità normalizzata. Le colonne "DA NON TOCCARE FORMULA" del
// foglio (commissioni, dovuto, saldi, rolling) qui sono SEMPRE calcolate dal
// motore in src/lib/calc.ts, mai memorizzate a mano.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled (pgbouncer) in produzione
  directUrl = env("DIRECT_URL") // connessione diretta per migrazioni/db push
}

// Partner commerciale (foglio "Database clienti 2026", colonne A-N)
model Partner {
  id                     String   @id @default(cuid())
  nome                   String   @unique
  ragioneSociale         String?
  categoria              String? // Pasticceria, Fiori, Boutique, Ristorante...
  citta                  String?
  servizi                String? // etichette: Vendor, Consegne, Magazzino...
  clienteAnno            String? // P.P. | Nuovo | Dismesso
  feePercent             Float? // % commissione su vendite come vendor
  debiti2025             Float    @default(0) // situazione debitoria al 31.12.2025
  pdrDebito              String? // piano di rientro debito
  crediti2025            Float    @default(0) // situazione creditizia al 31.12.2025
  ggPagamento            Int      @default(0) // giorni pagamento fattura (0 = vista fattura)
  compensazione          Boolean  @default(false) // crediti servizi compensati dagli incassi vendite
  commissioniADetrazione Boolean  @default(false) // commissioni detratte dal pagamento incassi
  addebitoDiretto        Boolean  @default(false)
  cartaCreditoApp        Boolean  @default(false)
  iban                   String? // per bonifici SEPA
  email                  String?
  telefono               String?
  // Referente amministrativo (chi paga le fatture): destinatario predefinito di
  // solleciti e pro-forma. Si può importare dal registro Anagrafiche.
  ammNome                String?
  ammEmail               String?
  ammTelefono            String?
  ammRuolo               String? // es. "Amministrazione", "Contabilità"
  note                   String?
  // Chiave di join con il registro Deluxy Anagrafiche (id del partner lì).
  // Popolata una volta per riconciliazione; è la "lingua comune di id" tra le app.
  anagraficaId           String?  @unique
  attivo                 Boolean  @default(true)
  fatture                FatturaServizio[]
  vendite                VenditaVendor[]
  saldi                  SaldoMensile[]
  transazioni            TransazioneBancaria[]
  proforme               ProForma[]
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

// Movimento dell'estratto conto importato da CSV/XLSX.
// hash = impronta di (data, importo, descrizione) per non duplicare
// ricaricando lo stesso estratto o periodi sovrapposti.
model TransazioneBancaria {
  id          String   @id @default(cuid())
  data        DateTime
  importo     Float // > 0 accredito, < 0 addebito
  divisa      String   @default("EUR")
  descrizione String
  controparte String?
  ibanControparte String? // IBAN del beneficiario/ordinante (bonifici SEPA), se nell'estratto
  hash        String   @unique
  fonte       String? // nome del file importato
  stato       String   @default("nuova") // nuova | registrata | ignorata
  esito       String? // annotazione dell'azione fatta (es. "fattura 181/2026 saldata")
  partnerId   String?
  partner     Partner? @relation(fields: [partnerId], references: [id])
  createdAt   DateTime @default(now())

  @@index([stato, data])
  @@index([partnerId])
  @@index([importo])
}

// Tipologia di servizio (aree del foglio "Piano Per Area")
model TipologiaServizio {
  id      String            @id @default(cuid())
  nome    String            @unique
  ordine  Int               @default(0)
  fatture FatturaServizio[]
}

// Servizi a fatturazione: fattura a credito emessa da Deluxy verso il partner
// (blocco mensile "Servizi A Fatturazione")
model FatturaServizio {
  id            String             @id @default(cuid())
  partnerId     String
  partner       Partner            @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  tipologiaId   String
  tipologia     TipologiaServizio  @relation(fields: [tipologiaId], references: [id])
  anno          Int
  mese          Int // 1-12, mese di competenza
  numero        String? // n° fattura FattureInCloud (es. 68/2026)
  emissione     DateTime?
  scadenza      DateTime?
  imponibile    Float // netto IVA
  aliquotaIva   Float              @default(22)
  pagata        Boolean            @default(false)
  // In compensazione: la fattura NON viene pagata in banca, ma scalata dai
  // prossimi importi dovuti al partner finché non è coperta.
  compensata    Boolean            @default(false)
  // true se "Saldata" ha registrato in automatico l'incasso (IVATO) sul saldo
  // del mese: serve per stornarlo correttamente se si riapre la fattura.
  incassoRegistrato Boolean        @default(false)
  dataPagamento DateTime?
  descrizione   String?
  sollecitoInviatoIl DateTime? // ultimo sollecito di pagamento inviato
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([partnerId, anno, mese])
  @@index([pagata, scadenza])
  @@index([anno])
  @@index([tipologiaId])
}

// Servizi come vendor: vendite fatte da Deluxy per conto del partner
// (blocco mensile "Servizi come VENDOR"). La commissione e il dovuto al
// partner sono calcolati: commissione = incasso * fee%; dovuto = incasso -
// commissione * (1 + IVA).
model VenditaVendor {
  id           String   @id @default(cuid())
  partnerId    String
  partner      Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  anno         Int
  mese         Int // 1-12, mese di competenza
  data         DateTime?
  descrizione  String?
  incassoLordo Float // importo venduto/incassato da Deluxy
  feePercent   Float // snapshot della fee del partner al momento della vendita
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([partnerId, anno, mese])
  @@index([anno])
}

// Chiusura mensile partner (blocchi "Extra" + "Saldi" del foglio):
// extra monetari, fattura commissioni, bonifico e note.
// Il saldo in compensazione e il residuo sono calcolati dal motore.
model SaldoMensile {
  id              String    @id @default(cuid())
  partnerId       String
  partner         Partner   @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  anno            Int
  mese            Int // 1-12
  commFattEmessa  Boolean   @default(false) // fattura commissioni emessa
  commFattNumero  String? // n° fattura commissioni FattureInCloud
  aggiunte        Float     @default(0) // importi extra a favore del partner
  detrazioni      Float     @default(0) // importi da scalare al partner
  dataPagamento   DateTime? // data in cui risulta saldato / incassato
  bonificoImporto Float? // >0 inviato al partner, <0 ricevuto dal partner
  bonificoData    DateTime?
  chiuso          Boolean   @default(false)
  note            String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([partnerId, anno, mese])
  @@index([anno])
}

// Voce extra del mese (blocco "Extra"): importo con segno — >0 aggiunta a favore
// del partner, <0 detrazione. Sono le singole voci; i totali aggiunte/detrazioni
// su SaldoMensile restano come cache sincronizzata (per non cambiare i calcoli).
model ExtraSaldo {
  id          String   @id @default(cuid())
  partnerId   String
  anno        Int
  mese        Int // 1-12
  descrizione String?
  importo     Float // >0 aggiunta, <0 detrazione
  createdAt   DateTime @default(now())

  @@index([partnerId, anno, mese])
}

// Pro-forma: documento non fiscale inviato al partner prima della fattura vera.
// Numerazione progressiva per anno (PF 1/2026, PF 2/2026…). Ciclo di vita:
// bozza → inviata → fatturata (con n° della fattura definitiva) oppure annullata.
// I totali (imponibile, IVA, totale documento) sono sempre calcolati dalle righe.
model ProForma {
  id            String    @id @default(cuid())
  numero        Int // progressivo nell'anno
  anno          Int // anno della numerazione
  partnerId     String
  partner       Partner   @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  data          DateTime // data del documento
  scadenza      DateTime? // termine di pagamento proposto
  oggetto       String? // causale in testa al documento
  note          String? // note in calce (condizioni, coordinate, ecc.)
  stato         String    @default("bozza") // bozza | inviata | fatturata | annullata
  inviataIl     DateTime?
  inviataA      String? // destinatario dell'ultimo invio
  fatturaNumero String? // n° fattura definitiva (quando stato = fatturata)
  fatturataIl   DateTime?
  annullataIl   DateTime?
  righe         ProFormaRiga[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([anno, numero])
  @@index([stato, data])
  @@index([partnerId])
}

// Riga di dettaglio della pro-forma: importo riga = quantita * prezzoUnitario.
model ProFormaRiga {
  id            String   @id @default(cuid())
  proFormaId    String
  proForma      ProForma @relation(fields: [proFormaId], references: [id], onDelete: Cascade)
  ordine        Int      @default(0)
  descrizione   String
  quantita      Float    @default(1)
  prezzoUnitario Float // netto IVA
  aliquotaIva   Float    @default(22)

  @@index([proFormaId])
}

// Pagamento diretto a un fornitore: i dati beneficiario vengono letti da una
// foto/IBAN con l'AI, verificati dall'operatore e predisposti come bonifico.
// L'app NON esegue il pagamento: genera il file SEPA da autorizzare in banca
// (Qonto/home banking). Stato: predisposto -> pagato oppure annullato.
// La foto NON viene salvata: l'AI la legge al volo, restano solo i dati.
model PagamentoDiretto {
  id            String    @id @default(cuid())
  beneficiario  String // intestatario del conto
  iban          String
  bic           String?
  importo       Float
  causale       String?
  fornitore     String? // riferimento interno / nome fornitore
  note          String?
  ibanValido    Boolean   @default(false) // esito del controllo mod-97 al salvataggio
  stato         String    @default("predisposto") // predisposto | pagato | annullato
  dataPagamento DateTime? // quando segnato pagato
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([stato, createdAt])
}

// Esito della riconciliazione di un cliente Fatture in Cloud con un partner /
// registro Anagrafiche. Traccia cosa è stato confermato (e inviato al registro)
// o ignorato, per non riproporlo e per audit. Chiave = nome cliente FIC.
model RiconciliazioneAnagrafica {
  id           String   @id @default(cuid())
  ficNome      String   @unique
  partnerId    String?
  anagraficaId String?
  stato        String // confermata | ignorata
  campiInviati String? // riepilogo dei campi proposti al registro
  esito        String? // ok | messaggio d'errore dell'ultimo invio
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Negozio Shopify collegato (uno per brand). Il token Admin (shpat_...) è
// salvato qui e usato server-side per scaricare gli ordini via Admin API.
model NegozioShopify {
  id        String          @id @default(cuid())
  brand     String          @unique // es. deluxyflowers.com
  dominio   String // es. fb72b1-2.myshopify.com
  token     String // Admin API access token (shpat_...)
  attivo    Boolean         @default(true)
  ultimaSync DateTime?
  ordini    OrdineShopify[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

// Ordine Shopify scaricato, con lo stato di riconciliazione con l'incasso.
// categoriaPagamento: bonifico | carta | contrassegno | altro — decide il flusso:
//  - bonifico  -> match 1:1 con un movimento bancario (TransazioneBancaria)
//  - carta     -> incassato via gateway (payout aggregato, riconciliato a blocco)
//  - contrassegno/altro -> incasso differito, da spuntare a mano
model OrdineShopify {
  id                 String         @id @default(cuid())
  negozioId          String
  negozio            NegozioShopify @relation(fields: [negozioId], references: [id], onDelete: Cascade)
  brand              String
  orderId            String // gid Shopify (globale, univoco per negozio)
  nome               String // es. #1234
  data               DateTime
  totale             Float
  valuta             String         @default("EUR")
  financialStatus    String? // PAID | PENDING | PARTIALLY_PAID | REFUNDED...
  gateway            String? // nomi gateway concatenati
  categoriaPagamento String         @default("altro") // bonifico | carta | contrassegno | altro
  clienteNome        String?
  clienteEmail       String?
  note               String?
  // riconciliazione
  statoRicon         String         @default("da_riconciliare") // da_riconciliare | riconciliato | incassato_gateway | ignorato
  transazioneId      String? // movimento bancario abbinato (se bonifico)
  riconciliatoIl     DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@unique([negozioId, orderId])
  @@index([statoRicon, data])
  @@index([categoriaPagamento])
}

// Registro centrale dei pagamenti riconciliati: ogni incasso/pagamento
// riconosciuto (ordine Shopify, fattura pagata, pagamento diretto, bonifico
// partner) ottiene un RIFERIMENTO univoco e stabile (PAY-<anno>-<progressivo>),
// così le altre app possono citarlo. Idempotente per (origineTipo, origineId):
// lo stesso record d'origine non genera due riferimenti.
model Pagamento {
  id          String   @id @default(cuid())
  riferimento String   @unique // es. PAY-2026-000123
  numero      Int // progressivo nell'anno
  anno        Int
  tipo        String // ordine_shopify | fattura_servizi | pagamento_diretto | bonifico_partner | incasso_partner
  direzione   String // in (incasso) | out (pagamento in uscita)
  importo     Float
  divisa      String   @default("EUR")
  data        DateTime // data del pagamento/incasso
  controparte String? // partner/cliente/fornitore
  partnerId   String?
  descrizione String?
  origineTipo String // tipo del record che ha generato il pagamento
  origineId   String // id del record d'origine
  createdAt   DateTime @default(now())

  @@unique([origineTipo, origineId])
  @@unique([anno, numero])
  @@index([tipo, data])
  @@index([partnerId])
}

// Attività finance da portare a termine: cose da fare legate all'amministrazione
// (sollecitare un pagamento, emettere una fattura, verificare un incasso…).
// Collegabile opzionalmente a un partner o a un riferimento (fattura/PAY-…).
model TaskFinance {
  id           String    @id @default(cuid())
  titolo       String
  note         String?
  stato        String    @default("aperto") // aperto | in_corso | fatto
  priorita     String    @default("media") // bassa | media | alta
  scadenza     DateTime?
  partnerId    String?
  partnerNome  String? // snapshot per l'elenco senza join
  riferimento  String? // riferimento libero: n° fattura, PAY-…, pro-forma…
  // condivisione con le altre app: chi ha creato il task e con quale id interno,
  // così un'app che crea/aggiorna lo stesso task non genera doppioni.
  origineApp   String? // app che ha aperto il task via API (es. deluxy-mail)
  idEsterno    String? // id del task nell'app d'origine
  completatoIl DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([origineApp, idEsterno])
  @@index([stato, scadenza])
}

// Impostazioni dell'app (chiave/valore): dati ordinante SEPA, preferenze
model Impostazione {
  chiave String @id
  valore String
}

// Storico delle fee di un partner: "dal mese/anno la fee diventa X%".
// Una vendita per un dato mese prende la fee valida in quel mese (la tariffa più
// recente con decorrenza <= mese), così lo storico resta invariato e i mesi
// successivi si aggiornano da soli. Fallback: partner.feePercent.
model TariffaPartner {
  id         String   @id @default(cuid())
  partnerId  String
  dalAnno    Int
  dalMese    Int // 1-12: la fee è valida DA questo mese in poi
  feePercent Float
  createdAt  DateTime @default(now())

  @@unique([partnerId, dalAnno, dalMese])
  @@index([partnerId])
}

// Regola di associazione: quando l'operatore assegna a mano un partner a un
// movimento non riconosciuto, la controparte viene memorizzata qui così i
// movimenti futuri dello stesso soggetto si riconoscono da soli.
model AssociazioneControparte {
  id          String   @id @default(cuid())
  chiave      String   @unique // controparte normalizzata
  partnerId   String
  partnerNome String
  esempio     String? // testo originale che ha generato la regola
  usi         Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Storico delle richieste di verifica arrivate via API da altri progetti.
model RichiestaVerifica {
  id              String   @id @default(cuid())
  origine         String? // app chiamante (header X-App o parametro)
  queryPartner    String // cosa è stato cercato
  partnerId       String?
  partnerNome     String?
  esito           String // trovato | non_trovato | non_autorizzato
  rispostaSintesi String? // riassunto testuale della situazione tornata
  ip              String?
  createdAt       DateTime @default(now())

  @@index([createdAt])
}

// Piano commerciale: actual 2025 / actual 2026 / forecast 2026
// (foglio "Piano commerciale e Forecast")
model Forecast {
  id          String  @id @default(cuid())
  partnerNome String
  servizio    String
  anno        Int // anno di riferimento del forecast (2026)
  mese        Int
  valPrecedente Float? // consuntivo anno precedente (2025)
  actual      Float?
  forecast    Float?

  @@unique([partnerNome, servizio, anno, mese])
}
