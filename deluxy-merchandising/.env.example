# Deluxy Merchandising — variabili d'ambiente (copiare in .env; MAI committare .env)

# --- Database ---
# Sviluppo locale: SQLite su file, nessun segreto necessario.
DATABASE_URL="file:./dev.db"
# In produzione si passa al Postgres condiviso Deluxy (schema "merchandising"),
# come le altre app. Vedi README per la migrazione.

# --- Protezione UI (opzionale, come le altre app Deluxy) ---
# Se impostata, la UI chiede questa password una volta (cookie di sessione).
# In sviluppo locale lasciarla vuota: la UI è aperta.
# MERCHANDISING_APP_PASSWORD=""

# --- Shopify (pubblicazione prodotti a valle) ---
# Necessarie SOLO per pubblicare davvero i prodotti sul negozio.
# Finché mancano, l'app prepara il payload e traccia lo stato ma non scrive su Shopify.
# SHOPIFY_STORE_DOMAIN="deluxyflowers.myshopify.com"
# SHOPIFY_ADMIN_TOKEN=""
