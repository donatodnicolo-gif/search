# ==== Deluxy Platform Next - variabili d'ambiente (copia in api/.env) ====

# Database (PostgreSQL ovunque)
# Dev locale:  docker compose up -d postgres
# Prod:        connection string "pooler" di Supabase (vedi api/.env.example)
DATABASE_URL="postgresql://deluxy:deluxy@localhost:5432/deluxy?schema=public"

# JWT
JWT_SECRET="cambia-questo-segreto-in-produzione"
JWT_EXPIRES_IN="8h"

# Server
PORT=3000

# CORS (origine del frontend, separale con virgola)
CORS_ORIGINS="http://localhost:4200"
