# ==== Deluxy Platform Next - variabili d'ambiente (copia in api/.env) ====

# Database
# Dev (SQLite):       file:./dev.db
# Prod (PostgreSQL):  postgresql://deluxy:deluxy@localhost:5432/deluxy?schema=public
#   NB: per PostgreSQL cambiare anche `provider = "postgresql"` in api/prisma/schema.prisma
DATABASE_URL="file:./dev.db"

# JWT
JWT_SECRET="cambia-questo-segreto-in-produzione"
JWT_EXPIRES_IN="8h"

# Server
PORT=3000

# CORS (origine del frontend, separale con virgola)
CORS_ORIGINS="http://localhost:4200"
