# --- Database ---
# PostgreSQL ovunque. Dev locale: il Postgres di docker-compose (`docker compose up -d postgres`).
DATABASE_URL="postgresql://deluxy:deluxy@localhost:5432/deluxy?schema=public"
# Prod (Vercel + Supabase): usare la connection string "pooler" di Supabase
# (porta 6543, pgbouncer) perche' su serverless ogni invocazione apre connessioni:
#   postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
# Per `prisma migrate deploy` serve invece la connessione diretta (porta 5432).

# --- Autenticazione ---
JWT_SECRET="cambia-questo-in-un-segreto-lungo-e-casuale"
JWT_EXPIRES_IN="7d"

# --- Server ---
PORT=3000
CORS_ORIGINS="http://localhost:4200"

# --- Web Push (notifiche) ---
# Genera una coppia dedicata all'ambiente (NON riusare quella di sviluppo):
#   node -e "console.log(require('web-push').generateVAPIDKeys())"
# La PUBLIC va anche su Vercel; la PRIVATE e' un segreto (solo qui / env di prod).
# Se mancano, l'app funziona con le sole notifiche in-app (niente push al browser).
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:info@deluxy.it"

# --- Registro centralizzato Anagrafiche (deluxy-anagrafiche) ---
# La piattaforma consegne è l'unica app con chiave di SCRITTURA: ogni partner
# creato/modificato qui viene inviato al registro (upsert). Sync best-effort:
# se queste variabili mancano o il registro è spento, l'operazione va comunque
# a buon fine e il mancato invio finisce nei log.
ANAGRAFICHE_URL="https://deluxy-anagrafiche.vercel.app"
# La chiave di SCRITTURA si legge dalla cassaforte dell'Hub (GET /api/keys):
# imposta HUB_URL + HUB_KEYS_TOKEN (stesso token dell'Hub) e la chiave vive
# SOLO nell'env dell'Hub (HUBKEY_ANAGRAFICHE). Ruoti in un posto solo.
HUB_URL="https://deluxy-hub.vercel.app"
HUB_KEYS_TOKEN=""
# Override d'emergenza: se valorizzata, si usa QUESTA e non si interroga l'Hub.
# (chiave generata su deluxy-anagrafiche: npm run chiave -- deluxy-platform --scrittura)
ANAGRAFICHE_API_KEY=""

# --- Webhook fatture pagate (inbound, macchina-a-macchina) ---
# Un sistema esterno (contabilità/incassi) chiama POST /api/v1/invoices/webhook/paid
# con header `x-api-key: <questa chiave>` e body { number: "FAT-2026-3" } (o { id })
# per segnalare che una fattura è stata pagata. Se vuota, il webhook è disattivato (401).
# Scegli una stringa lunga e casuale; NON committare il valore reale.
INVOICE_WEBHOOK_API_KEY=""
