# --- Database ---
# Dev locale: SQLite. Produzione: PostgreSQL.
DATABASE_URL="file:./prisma/dev.db"

# --- Autenticazione ---
JWT_SECRET="cambia-questo-in-un-segreto-lungo-e-casuale"
JWT_EXPIRES_IN="7d"

# --- Server ---
PORT=3000
CORS_ORIGINS="http://localhost:4200"

# --- Registro centralizzato Anagrafiche (deluxy-anagrafiche) ---
# La piattaforma consegne è l'unica app con chiave di SCRITTURA: ogni partner
# creato/modificato qui viene inviato al registro (upsert). Sync best-effort:
# se queste variabili mancano o il registro è spento, l'operazione va comunque
# a buon fine e il mancato invio finisce nei log.
ANAGRAFICHE_URL="https://deluxy-anagrafiche.vercel.app"
# Chiave con permesso di scrittura, generata su deluxy-anagrafiche:
#   npm run chiave -- deluxy-platform --scrittura
# NON committare la chiave reale: va solo nel .env locale / nelle env di produzione.
ANAGRAFICHE_API_KEY=""
