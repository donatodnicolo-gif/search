# ============================================================
#  Connessione al DATABASE DI PRODUZIONE Deluxy (MySQL)
#  Copia questo file in  api/.env.legacy  (è gitignored) e
#  compila i valori reali. NON incollare la password in chat.
# ============================================================

# Host o IP del MySQL di produzione (MEGLIO: una replica in sola lettura)
LEGACY_MYSQL_HOST=

# Porta (di solito 3306)
LEGACY_MYSQL_PORT=3306

# Nome del database/schema
LEGACY_MYSQL_DATABASE=

# Utente DEDICATO IN SOLA LETTURA (vedi grant SQL sotto), non l'utente dell'app
LEGACY_MYSQL_USER=

# Password di quell'utente
LEGACY_MYSQL_PASSWORD=

# --- Stringa che userà Prisma per l'introspezione (lascia così: si compone dalle variabili sopra) ---
# Se il server richiede SSL, aggiungi in fondo:  &sslaccept=strict
DATABASE_URL="mysql://${LEGACY_MYSQL_USER}:${LEGACY_MYSQL_PASSWORD}@${LEGACY_MYSQL_HOST}:${LEGACY_MYSQL_PORT}/${LEGACY_MYSQL_DATABASE}"
